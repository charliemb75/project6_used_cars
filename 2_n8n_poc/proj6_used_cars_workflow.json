              "content": "=Make: {{ $('Form Trigger').item.json.Make }},\nModel: {{ $('Form Trigger').item.json.Model }},\nGeneration: {{ $json.selectedGeneration }},"
            },
            {
              "role": "system",
              "content": "You are a helpful assistant who researches vehicle data to help potential buyers of used cars.\n\nFor the make and model and generation given by the user, search:\n- All possible body types (sedan, coupe, 3 or 5 door hatchback, mpv...), including the brand-specific nomenclature\n- All possible powertrain options for each body type (combustion engines and/other electric motors including the configuration, max power in hp, max torque in Nm, battery sizes if electric, gearbox choices if combustion, driven wheels). If there are commercial names for the powertrains or specific trim levels associated to them, include them.\n\nReturn only this information, and it in md formatting\n\nExample 1:\n\n## Saloon and Estate\n2.0 L petrol, Inline 4, 250 HP, 300 Nm, 8-speed automatic, RWD\n3.0 L petrol, Inline 6 MHEV, 380 HP, 500 Nm, 7-speed dual clutch, AWD\n3.0 L diesel, inline 6, 300 HP, 500 Nm, 8-speed automatic, RWD\n\n# Coupé\n3.0 L petrol, Inline 6 MHEV, 380 HP, 500 Nm, 7-speed dual clutch, RWD\n4.0 L petrol, V8, 500 HP, 750 Nm, 7-speed dual clutch, AWD\n\nExample 2:\n\n# 5-door hatchback\nBase: 1.0 L petrol, Inline 3, 100 HP, 150 Nm, 6-speed manual, FWD\nBase: 1.0 L petrol, Inline 3, 100 HP, 150 Nm, 6-speed dual clutch, FWD\nGTI: 2.0 L petrol, Inline 4, 200 HP, 320 Nm, 6-speed dual clutch, FWD\nEco: BEV, 150 HP, 300 Nm, 60 kWh, FWD"
            }
          ]
