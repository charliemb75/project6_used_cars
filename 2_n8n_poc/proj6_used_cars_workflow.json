    {
      "parameters": {
        "jsCode": "const generations = $input.first().json.generations;\n\nconst numbered = generations\n  .map((g, i) => `${i + 1}. ${g}`)\n  .join('\\n');\n\nreturn [{ json: { generations, numbered } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
