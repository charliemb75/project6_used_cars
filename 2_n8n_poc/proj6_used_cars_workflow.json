        },
        "responses": {
          "values": [
            {
              "content": "=Make: {{ $('Form Trigger').item.json.Make }},\nModel: {{ $('Form Trigger').item.json.Model }},"
            },
            {
              "role": "system",
              "content": "You are a helpful assistant who researches vehicle data to help potential buyers of used cars.\n\nFor the make and model given by the user, list all generations with their year ranges. Return a JSON with a list of generations.\n\nIf there are any widely known manufacturer codes, return them as well. If there restylings/facelifts, include them too with their own list entries.\n\nIn case of ambiguity, return European-market models.\n\nIf there is only one generation for a model, return just that generation. Do not anticipate and return the versions within that generation.\n\nExamples:\n\nInputs: Make: BMW, Model: 3 series\nOutput: {\"generations\": [\"1975 - 1981, E21\", \"1982 - 1990, E30\", \"1990 - 1997, E36\", \"1997 - 2004, E46\", \"2005 - 2008, E90\", \"2008 - 2011, E90 facelift (LCI)\"...]}\n\nInputs: Make: Nissan, Model: Skyline\nOutput: {\"generations\": [..., \"1989 - 1993, R32\", \"1993 - 1998, R33\", \"1998 - 2002, R34\"]}\n\nInputs: Make: Ford, Model: Focus\nOutput: {\"generations\": [\"1998 - 2004, mk1\", \"2004 - 2010, mk2\", \"2010 - 2018, mk3\", \"2018 - 2025, mk4\"]}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.3,
      "position": [
        1280,
        -256
      ],
      "id": "c1a9539c-acd9-42bd-8aef-e5a878b7b60d",
      "name": "Search generations",
      "credentials": {
