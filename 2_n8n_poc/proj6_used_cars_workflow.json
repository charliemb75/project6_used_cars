    {
      "parameters": {
        "jsCode": "const submitted = $input.first().json.submittedAt;\nconst dt = new Date(submitted);\n\nconst parts = new Intl.DateTimeFormat('en-CA', {\n  timeZone: 'Europe/Berlin',\n  year: 'numeric', month: '2-digit', day: '2-digit',\n  hour: '2-digit', minute: '2-digit', second: '2-digit',\n  hour12: false\n}).formatToParts(dt);\n\nconst get = (type) => parts.find(p => p.type === type).value;\nconst date = `${get('year')}${get('month')}${get('day')}`;\nconst time = `${get('hour')}${get('minute')}${get('second')}`;\n\nconst make  = $input.first().json.Make.toLowerCase();\nconst model = $input.first().json.Model.toLowerCase();\n\nreturn [{ json: { filename: `${date}_${time}_${make}_${model}` } }];"
      },
